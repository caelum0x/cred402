{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://cred402.onrender.com/api/:path*" },
    { "source": "/v1/:path*", "destination": "https://cred402.onrender.com/v1/:path*" },
    { "source": "/graphql", "destination": "https://cred402.onrender.com/graphql" },
    { "source": "/((?!assets/|.*\\.).*)", "destination": "/index.html" }
  ]
}
