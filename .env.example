# Cred402 environment — copy to .env and fill in. .env is gitignored.
# Everything below is OPTIONAL: with nothing set, Cred402 runs fully in
# simulation/free-API mode (deterministic demo + 87 tests stay green). Each block
# activates a REAL integration when its keys are present.

# ── p8: real Casper Testnet ────────────────────────────────────────────────
# sim (default) keeps the in-memory ledger; testnet routes writes to a live node.
CRED402_CHAIN=sim
# Casper 2.0 testnet JSON-RPC (reads work with no key — used by `npm run casper:health`).
CRED402_NODE=https://node.testnet.casper.network/rpc
CRED402_CASPER_NODE=https://node.testnet.casper.network
CRED402_CHAIN_NAME=casper-test
# Casper Sidecar SSE event feed (casper-network/casper-sidecar). Unset → in-process
# EventBus. Set to consume a live node's events: npm run casper:sidecar
CRED402_SIDECAR_URL=http://127.0.0.1:19999
# Path to a funded Testnet secret-key PEM (faucet: https://testnet.cspr.live/tools/faucet).
# Required only for live deploys / writes. NEVER commit the key itself.
CRED402_SECRET_KEY=/absolute/path/to/secret_key.pem
CRED402_KEY_ALGO=ed25519

# ── p9: real x402 facilitator + data + MCP ─────────────────────────────────
# make-software/casper-x402 facilitator (x402 V2). Run it on :4022, then set this
# to verify/settle CEP-18 transfer_with_authorization payments for real.
# Unset → Cred402's built-in ed25519 x402 verifier (the default, no service needed).
CRED402_X402_FACILITATOR_URL=http://localhost:4022
# Open-Meteo solar/GHI is free and needs NO key (used live by api/rwa_data).
# Optional real EU power-market data (ENTSO-E) — request a token at transparency.entsoe.eu.
ENTSOE_API_TOKEN=
# The official MCP server (npm run mcp:sdk) needs no env — connect any MCP client.

# ── p10: real RealFi (Stripe/Plaid) + real cross-chain (Base Sepolia) ──────
# Stripe TEST mode (real signature verification on the webhook route).
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Plaid SANDBOX (real API, no real bank).
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# Base Sepolia EVM satellite deploy (forge). Faucet: https://www.alchemy.com/faucets/base-sepolia
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
ARBITRUM_SEPOLIA_RPC_URL=
ETHERSCAN_API_KEY=
# Deploy inputs for contracts/evm/script/Deploy.s.sol (NEVER commit the key):
PRIVATE_KEY=0xYOUR_FUNDED_BASE_SEPOLIA_KEY
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
CHAIN_CAIP2=eip155:84532
